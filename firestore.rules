rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /goals/{goalId} {
        allow read, write: if isOwner(uid);
      }

      match /labels/{labelId} {
        allow read, write: if isOwner(uid);
      }

      match /days/{dayId} {
        allow read, write: if isOwner(uid);

        match /meals/{mealId} {
          allow read, write: if isOwner(uid);
        }
      }

      match /foods/{foodId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
