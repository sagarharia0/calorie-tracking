rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Email allowlist — single-tenant personal app. Add an email here AND
    // mirror in functions/src/auth.ts ALLOWED_EMAILS to grant a new user.
    function allowedEmail() {
      return request.auth != null
             && request.auth.token.email in [
               'sagarharia@gmail.com',
             ];
    }

    function isOwner(uid) {
      return request.auth != null
             && request.auth.uid == uid
             && allowedEmail();
    }

    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /goals/{goalId} {
        allow read, write: if isOwner(uid);
      }

      match /labels/{labelId} {
        allow read, write: if isOwner(uid);
      }

      match /days/{dayId} {
        allow read, write: if isOwner(uid);

        match /meals/{mealId} {
          allow read, write: if isOwner(uid);
        }
      }

      match /foods/{foodId} {
        allow read, write: if isOwner(uid);
      }
    }
  }
}
